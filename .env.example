# ============================================================
# Stock Intelligence Platform — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com valores reais.
# ============================================================

# === Banco de dados ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stock_intelligence

# === Segurança — API administrativa ===
# Chave usada nos endpoints mutáveis (POST /assets, POST /ingestion/run, etc.)
# Header obrigatório: X-Api-Key: <valor>
# Troque por um valor longo e aleatório em produção.
API_SECRET_KEY=change-me-in-production

# === Ambiente ===
# Valores possíveis: development | staging | production
ENVIRONMENT=development

# === CORS ===
# Origins permitidas (separadas por vírgula).
# Em produção, substitua pelo domínio real; nunca use '*' em produção.
# Exemplo produção: https://app.meudominio.com
CORS_ORIGINS=http://localhost:3000

# Métodos permitidos (separados por vírgula). Padrão: GET,POST,OPTIONS
CORS_METHODS=GET,POST,OPTIONS

# Headers permitidos (separados por vírgula).
CORS_ALLOW_HEADERS=Content-Type,X-Api-Key,X-Request-ID

# === Paginação ===
# Limite padrão por página. Máximo geral: 100. Máximo trades: 500.
PAGINATION_DEFAULT_LIMIT=50
PAGINATION_MAX_LIMIT=100
PAGINATION_MAX_LIMIT_TRADES=500

# === Rate limiting (por instância — não distribuído) ===
# Limites por IP por minuto. Baseados em memória local; reiniciam com o processo.
# Não substituem autenticação nem protegem contra ataques distribuídos.
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_RANKINGS=30/minute
RATE_LIMIT_ANALYSIS=30/minute
RATE_LIMIT_ADMIN=20/minute
RATE_LIMIT_INGESTION=10/minute
RATE_LIMIT_BACKTESTS=10/minute

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === LLM (Sprint 7) ===
LLM_PROVIDER=
LLM_API_KEY=

# === Alertas (Sprint 7) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
